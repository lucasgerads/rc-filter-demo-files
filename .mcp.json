{
  "mcpServers": {
    "lecroy-scope": {
      "type": "stdio",
      "command": "uvx",
      "args": ["lecroy-mcp@latest"],
      "env": {
        "LECROY_HOST": "192.168.1.111",
        "LECROY_PROBE_C1": "none",
        "LECROY_PROBE_C2": "none",
        "LECROY_PROBE_C3": "10",
        "LECROY_PROBE_C4": "10"
      }
    },
    "spicelib": {
      "type": "stdio",
      "command": "uvx",
      "args": ["spicelib-mcp@latest"],
      "env": {
        "SPICE_SIMULATOR": "ngspice"
      }
    }
  }
}
